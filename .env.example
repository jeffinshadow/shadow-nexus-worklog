# ------------------------------------------------------------------
# Copie para .env e preencha. O .env NUNCA vai para o git (.gitignore).
# Os valores a substituir estao marcados abaixo: o deploy.sh bloqueia o
# deploy enquanto algum desses marcadores continuar num valor do .env
# (ele ignora comentarios).
# ------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGEME_senha_forte_do_postgres
POSTGRES_DB=nexus_worklog

# String de conexao do backend -> Postgres.
# host = 'db' (nome do servico na rede interna). Use os MESMOS user/senha/db
# definidos acima (troque tambem a senha aqui).
DATABASE_URL=postgresql://nexus:CHANGEME_senha_forte_do_postgres@db:5432/nexus_worklog

# Segredo da aplicacao (pepper das sessoes). Gere um valor forte:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#   openssl rand -base64 48
SECRET_KEY=CHANGEME_gere_um_secret_forte

# Sessao
SESSION_TTL_DAYS=7
# Em producao (HTTPS via tunnel) deixe true. Em teste local sem HTTPS use false.
COOKIE_SECURE=true

# Fuso horario da aplicacao (define "hoje", inicio de semana/mes).
APP_TZ=America/Sao_Paulo

# Admin master (seed no primeiro start; so cria se ainda nao existir).
# Loga com esta senha e e OBRIGADO a troca-la no primeiro acesso.
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=CHANGEME_senha_inicial_do_admin

# ------------------------------------------------------------------
# Cloudflare Tunnel (credenciais)
# Token do dashboard Zero Trust: Networks -> Tunnels -> seu tunnel -> instalar.
# Aponte o public hostname do tunnel para http://web:80.
# ------------------------------------------------------------------
TUNNEL_TOKEN=CHANGEME_token_do_cloudflared
