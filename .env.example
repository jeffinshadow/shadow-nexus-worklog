# ------------------------------------------------------------------
# Copie para .env e preencha. O .env NUNCA vai para o git (.gitignore).
# ------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=nexus_worklog

# String de conexao do backend -> Postgres.
# host = 'db' (nome do servico na rede interna). Mesmos user/senha/db acima.
DATABASE_URL=postgresql://nexus:troque-por-uma-senha-forte@db:5432/nexus_worklog

# Segredo da aplicacao (pepper das sessoes). Gere um valor forte:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=gere-um-valor-aleatorio-forte

# Sessao
SESSION_TTL_DAYS=7
# Em producao (HTTPS via tunnel) deixe true. Em teste local sem HTTPS use false.
COOKIE_SECURE=true

# Fuso horario da aplicacao (define "hoje", inicio de semana/mes).
APP_TZ=America/Sao_Paulo

# Admin master (seed no primeiro start; so cria se ainda nao existir).
# Loga com esta senha e e OBRIGADO a troca-la no primeiro acesso.
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=troque-imediatamente

# Cloudflare Tunnel (token do dashboard Zero Trust -> Tunnels -> seu tunnel).
TUNNEL_TOKEN=cole-o-token-do-cloudflared
